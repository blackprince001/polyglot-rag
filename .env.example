DATABASE_URL=postgres://postgres:postgres@localhost/postgres
EMBEDDINGS_SERVICE_URL=

# Server bind address and worker pool size
HOST=0.0.0.0
PORT=3000
WORKER_COUNT=3
CORS_ALLOWED_ORIGINS=

# Master key for the tenant & API key management endpoints
# (POST /tenants, GET /tenants, POST /tenants/{id}/keys, etc.).
# If unset, those routes return 503. Use a long random string in production.
TENANT_MANAGEMENT_KEY=

# ── Storage backend ─────────────────────────────────────────────────────
# local      — bytes on the local filesystem under UPLOAD_DIR
# s3         — AWS S3 or any S3-compatible store (R2, MinIO, Wasabi)
# cloudinary — Cloudinary
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads

# Presigned URL TTLs. Object-store backends encode these into the signed URL.
# Local backend ignores them (the streaming route is always available).
PRESIGNED_UPLOAD_TTL_SECS=900
PRESIGNED_DOWNLOAD_TTL_SECS=300

# S3 backend (required when STORAGE_BACKEND=s3).
# The defaults below match the dev/localstack.docker-compose.yml stack.
S3_BUCKET=polyrag-local
S3_REGION=us-east-1
# Custom endpoint for S3-compatible stores (R2, MinIO, Wasabi, localstack).
# Leave empty for real AWS.
S3_ENDPOINT=http://localhost:4566
# Path-style addressing (needed for MinIO / localstack). false for real AWS.
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test

# Cloudinary backend (required when STORAGE_BACKEND=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional folder prefix for all assets.
CLOUDINARY_FOLDER=

# ── Document chunking ───────────────────────────────────────────────────
# Override defaults for the text-splitter used during document ingestion.
CHUNK_SIZE=578
CHUNK_OVERLAP=102
# Cap the number of chunks per document (no limit when unset).
MAX_CHUNKS_PER_DOCUMENT=
# Reject documents whose content yields fewer than this many characters.
MIN_CHUNK_SIZE=10

# ── Storage janitor ─────────────────────────────────────────────────────
# Default = 2 × PRESIGNED_UPLOAD_TTL_SECS, floored at 1800s. Set explicitly
# to override.
JANITOR_INTERVAL_SECS=300
JANITOR_DANGLING_THRESHOLD_SECS=
JANITOR_STALE_PROCESSING_SECS=1800
